<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:top="3dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A3d79ca" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#2563EB"
                android:centerColor="#3d79ca"
                android:endColor="#60A5FA"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>