<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF4FF"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Top wave header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_gradient_header"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_icon_glow_circle"
            android:elevation="6dp">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_idle_lock"
                app:tint="#3d79ca"/>

        </FrameLayout>

    </LinearLayout>

    <!-- White card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginTop="-40dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="494dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <!-- Blue accent divider -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.01"
                android:text="Forgot Password"
                android:textColor="#1A2D5A"
                android:textSize="26sp"
                android:textStyle="bold" />

            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_divider_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:lineSpacingMultiplier="1.5"
                android:maxWidth="420dp"
                android:text="Please enter the email address you used to register to receive a link to reset your password."
                android:textAlignment="center"
                android:textColor="#7A9AC4"
                android:textSize="14sp" />

            <!-- Email label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.06"
                android:text="Email Address"
                android:textColor="#5B8FD4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Email input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundColor="#F4F8FF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="#3D79CA"
                app:boxStrokeWidth="1.5dp"
                app:hintEnabled="false">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginHorizontal="0dp"
                    android:background="@android:color/transparent"
                    android:hint="Input your email address"
                    android:inputType="textEmailAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1A2D5A"
                    android:textColorHint="#A0B4D0"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btn_Reset"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="0dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#3D79CA"
                android:elevation="6dp"
                android:letterSpacing="0.02"
                android:text="Send Password Reset Link"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="26dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="16dp"
                android:text="← Back to Login"
                android:textColor="#3d79ca"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

