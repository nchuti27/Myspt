<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true"
    tools:context=".Register"> <ImageView
    android:id="@+id/back2login"
    android:layout_width="48dp"
    android:layout_height="48dp"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:padding="12dp"
    android:background="?attr/selectableItemBackgroundBorderless"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:srcCompat="@drawable/ic_arrow_back"
    app:tint="#000000" />

    <TextView
        android:id="@+id/regis_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Register"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintBottom_toTopOf="@+id/name_pt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <EditText
        android:id="@+id/name_pt"
        android:layout_width="280dp"
        android:layout_height="58dp"
        android:layout_marginTop="32dp"
        android:background="@android:drawable/edit_text"
        android:hint="Name"
        android:inputType="textPersonName"
        android:paddingHorizontal="12dp"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/usern_pt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/regis_txt" />

    <EditText
        android:id="@+id/usern_pt"
        android:layout_width="280dp"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:hint="Username"
        android:paddingHorizontal="12dp"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/Rmail_pt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_pt" />

    <EditText
        android:id="@+id/Rmail_pt"
        android:layout_width="280dp"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="12dp"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/pw_pt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/usern_pt" />

    <EditText
        android:id="@+id/pw_pt"
        android:layout_width="280dp"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toTopOf="@+id/conf_pt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Rmail_pt" />

    <EditText
        android:id="@+id/conf_pt"
        android:layout_width="280dp"
        android:layout_height="58dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toTopOf="@+id/regis_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pw_pt" />

    <Button
        android:id="@+id/regis_btn"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#3D79ca"
        android:text="Register"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/conf_pt" />

</androidx.constraintlayout.widget.ConstraintLayout>